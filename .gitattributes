# إجبار غيت هب على حساب ملفات الـ Razor بالكامل كلغة سي شارب
*.razor linguist-language=C#

# تجاهل لغات التصميم والـ HTML بالكامل لكي لا تظهر في الشريط
*.scss linguist-vendored
*.css linguist-vendored
*.html linguist-vendored
*.js linguist-vendored

# تجاهل مجلدات النظام المؤقتة ومجلد الحزم الجاهزة
**/bin/** linguist-vendored
**/obj/** linguist-vendored
**/wwwroot/lib/** linguist-vendored

# إبراز كود السي شارب وجعلها اللغة المكتشفة الأساسية
*.cs linguist-detectable=true
